# Copia este archivo como .env para desarrollo local
# NUNCA subas el archivo .env real a GitHub

# Clave secreta de Flask (genera una aleatoria)
SECRET_KEY=cambia-esto-por-una-cadena-secreta-larga

# URL de la base de datos
# Para desarrollo local usa SQLite (no requiere instalación):
DATABASE_URL=sqlite:///passwords.db
# Para producción con PostgreSQL:
# DATABASE_URL=postgresql://usuario:contraseña@host/basededatos

# Clave de cifrado para las contraseñas almacenadas
# Genera una con: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# IMPORTANTE: Si pierdes esta clave, no podrás descifrar las contraseñas guardadas
ENCRYPTION_KEY=
